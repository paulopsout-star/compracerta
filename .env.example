# Database
DATABASE_URL="postgresql://user:password@localhost:5432/compracerta?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_API_URL="https://graph.facebook.com/v18.0"
WHATSAPP_API_TOKEN="your-whatsapp-api-token"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"

# Canal do Repasse Integration
CANAL_REPASSE_API_URL="https://api.canaldorepasse.com.br"
CANAL_REPASSE_API_KEY="your-api-key"

# Avaliador Digital (Read Replica)
AVALIADOR_DB_URL="postgresql://readonly:password@avaliador-replica:5432/avaliador"

# File Storage (S3)
AWS_S3_BUCKET="compracerta-uploads"
AWS_REGION="sa-east-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"

# Redis (Cache)
REDIS_URL="redis://localhost:6379"
