# Database
DATABASE_URL="postgresql://user:password@localhost:5432/compracerta?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_API_URL="https://graph.facebook.com/v18.0"
WHATSAPP_API_TOKEN="your-whatsapp-api-token"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"

# Canal do Repasse — SQL Server (Marketplace)
CANAL_REPASSE_SYNC_ENABLED="false"
CANAL_REPASSE_SQL_HOST=""
CANAL_REPASSE_SQL_PORT="1433"
CANAL_REPASSE_SQL_DATABASE=""
CANAL_REPASSE_SQL_USER=""
CANAL_REPASSE_SQL_PASSWORD=""

# Avaliador Digital — SQL Server
AVALIADOR_SYNC_ENABLED="false"
AVALIADOR_SQL_HOST=""
AVALIADOR_SQL_PORT="1433"
AVALIADOR_SQL_DATABASE=""
AVALIADOR_SQL_USER=""
AVALIADOR_SQL_PASSWORD=""

# File Storage (S3)
AWS_S3_BUCKET="compracerta-uploads"
AWS_REGION="sa-east-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"

# Redis (Cache)
REDIS_URL="redis://localhost:6379"
