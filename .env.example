# Database
DATABASE_URL="postgresql://user:password@localhost:5432/compracerta?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# WhatsApp — Z-API (provedor principal)
ZAPI_BASE_URL="https://api.z-api.io"
ZAPI_INSTANCE_ID=""
ZAPI_INSTANCE_TOKEN=""
ZAPI_CLIENT_TOKEN=""
ZAPI_WEBHOOK_SECRET=""

# WhatsApp — Meta Cloud API (fallback legado; desligado quando whatsapp.zapi.enabled=true)
WHATSAPP_API_URL="https://graph.facebook.com/v18.0"
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# LLM — Claude (Anthropic)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-5"

# Avaliador Digital — API REST
AVALIADOR_API_ENABLED="false"
AVALIADOR_API_URL=""
AVALIADOR_API_KEY=""

# Canal do Repasse — API REST (quando disponível)
CANAL_REPASSE_API_ENABLED="false"
CANAL_REPASSE_API_URL=""
CANAL_REPASSE_API_KEY=""

# File Storage (S3)
AWS_S3_BUCKET="compracerta-uploads"
AWS_REGION="sa-east-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"

# Redis (Cache)
REDIS_URL="redis://localhost:6379"
