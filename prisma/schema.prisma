generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  vendedor
  gestor
  lojista
  admin
}

enum UrgencyLevel {
  baixa
  media
  alta
}

enum WishStatus {
  procurando
  match_encontrado
  em_negociacao
  convertido
  perdido
  expirado
}

enum OfferSource {
  avaliador
  marketplace
  estoque_lojista
}

enum MatchStatus {
  novo
  notificado
  aceito
  rejeitado
  convertido
}

enum NotificationChannel {
  whatsapp
  email
  sistema
}

enum NotificationStatus {
  pendente
  enviado
  entregue
  lido
  respondido
  erro
}

enum TransmissionType {
  manual
  automatico
  indiferente
}

enum FuelType {
  flex
  gasolina
  diesel
  hibrido
  eletrico
  indiferente
}

enum UploadFormat {
  csv
  xls
  xlsx
  pdf
}

enum UploadStatus {
  processando
  concluido
  erro
  revisao_pendente
}

model User {
  id             String       @id @default(cuid())
  name           String
  email          String       @unique
  emailVerified  DateTime?
  passwordHash   String?
  phone          String?
  role           UserRole     @default(vendedor)
  dealershipId   String?
  dealerStoreId  String?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  dealership     Dealership?  @relation(fields: [dealershipId], references: [id])
  dealerStore    DealerStore? @relation(fields: [dealerStoreId], references: [id])
  wishes         Wish[]
  notifications  Notification[]
  auditLogs      AuditLog[]
  accounts       Account[]
  sessions       Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Dealership {
  id        String   @id @default(cuid())
  name      String
  cnpj      String   @unique
  city      String
  state     String   @db.Char(2)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  wishes    Wish[]

  @@map("dealerships")
}

model DealerStore {
  id              String   @id @default(cuid())
  name            String
  cnpj            String   @unique
  city            String
  state           String   @db.Char(2)
  active          Boolean  @default(true)
  canalRepasseId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users           User[]
  stockUploads    StockUpload[]
  offers          Offer[]

  @@map("dealer_stores")
}

model Wish {
  id             String          @id @default(cuid())
  sellerId       String
  dealershipId   String?
  clientName     String
  clientPhone    String
  clientCpf      String?
  clientEmail    String?
  brand          String
  model          String
  version        String?
  yearMin        Int?
  yearMax        Int?
  kmMax          Int?
  priceMin       Float?
  priceMax       Float?
  colors         String[]        @default([])
  transmission   TransmissionType @default(indiferente)
  fuel           FuelType        @default(indiferente)
  cityRef        String?
  stateRef       String?         @db.Char(2)
  radiusKm       Int             @default(100)
  urgency        UrgencyLevel    @default(media)
  validityDays   Int             @default(30)
  notes          String?
  lgpdConsent    Boolean         @default(false)
  status         WishStatus      @default(procurando)
  createdAt      DateTime        @default(now())
  expiresAt      DateTime
  updatedAt      DateTime        @updatedAt

  seller         User            @relation(fields: [sellerId], references: [id])
  dealership     Dealership?     @relation(fields: [dealershipId], references: [id])
  matches        Match[]

  @@index([status])
  @@index([brand, model])
  @@index([sellerId])
  @@index([expiresAt])
  @@map("wishes")
}

model Offer {
  id             String      @id @default(cuid())
  source         OfferSource
  sourceId       String
  plate          String?
  brand          String
  model          String
  version        String?
  year           Int
  km             Int
  color          String?
  price          Float
  city           String
  state          String      @db.Char(2)
  active         Boolean     @default(true)
  dealerStoreId  String?
  syncedAt       DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  dealerStore    DealerStore? @relation(fields: [dealerStoreId], references: [id])
  matches        Match[]

  @@unique([source, sourceId])
  @@index([brand, model])
  @@index([active])
  @@index([source])
  @@map("offers")
}

model Match {
  id            String       @id @default(cuid())
  wishId        String
  offerId       String
  score         Float
  status        MatchStatus  @default(novo)
  createdAt     DateTime     @default(now())
  convertedAt   DateTime?
  updatedAt     DateTime     @updatedAt

  wish          Wish         @relation(fields: [wishId], references: [id])
  offer         Offer        @relation(fields: [offerId], references: [id])
  notifications Notification[]

  @@unique([wishId, offerId])
  @@index([status])
  @@index([score])
  @@map("matches")
}

model Notification {
  id            String              @id @default(cuid())
  matchId       String
  recipientId   String
  channel       NotificationChannel @default(whatsapp)
  template      String
  content       String
  status        NotificationStatus  @default(pendente)
  sentAt        DateTime?
  readAt        DateTime?
  respondedAt   DateTime?
  createdAt     DateTime            @default(now())

  match         Match               @relation(fields: [matchId], references: [id])
  recipient     User                @relation(fields: [recipientId], references: [id])

  @@index([status])
  @@index([recipientId])
  @@index([matchId])
  @@map("notifications")
}

model StockUpload {
  id              String       @id @default(cuid())
  dealerStoreId   String
  fileUrl         String
  format          UploadFormat
  status          UploadStatus @default(processando)
  linesProcessed  Int          @default(0)
  linesWithError  Int          @default(0)
  errorDetails    Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  dealerStore     DealerStore  @relation(fields: [dealerStoreId], references: [id])

  @@map("stock_uploads")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entity      String
  entityId    String?
  dataBefore  Json?
  dataAfter   Json?
  ip          String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model FipeReference {
  id        String @id @default(cuid())
  brand     String
  model     String
  version   String?
  yearStart Int?
  yearEnd   Int?
  fipeCode  String?

  @@index([brand])
  @@index([brand, model])
  @@map("fipe_references")
}

// =====================================================================
// WhatsApp conversacional (Z-API) — ver spec "prompt-final-whatsapp-compra-certa.md"
// =====================================================================

enum ConversationState {
  idle
  collecting_wish
  confirming
  viewing_status
  viewing_matches
  editing_field
  getting_help
  waiting_feedback
}

enum InboundContentType {
  text
  audio
  image
  button
  list
  other
}

enum OutboundStatus {
  pending
  sent
  delivered
  read
  failed
}

model ConversationSession {
  id            String            @id @default(cuid())
  sellerId      String?           @map("seller_id")
  phoneE164     String            @map("phone_e164")
  state         ConversationState @default(idle)
  currentIntent String?           @map("current_intent")
  draftWish     Json?             @map("draft_wish")
  context       Json?
  lastMessageAt DateTime          @map("last_message_at")
  expiresAt     DateTime          @map("expires_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  inboundMessages  WhatsAppInboundMessage[]

  @@index([phoneE164])
  @@index([sellerId])
  @@index([expiresAt])
  @@map("conversation_sessions")
}

model WhatsAppInboundMessage {
  id                 String              @id @default(cuid())
  providerMessageId  String              @unique @map("provider_message_id")
  phoneE164          String              @map("phone_e164")
  sellerId           String?             @map("seller_id")
  contentType        InboundContentType  @default(text) @map("content_type")
  content            String?
  mediaUrl           String?             @map("media_url")
  rawPayload         Json?               @map("raw_payload")
  receivedAt         DateTime            @map("received_at")
  processedAt        DateTime?           @map("processed_at")
  sessionId          String?             @map("session_id")
  createdAt          DateTime            @default(now()) @map("created_at")

  session            ConversationSession? @relation(fields: [sessionId], references: [id])

  @@index([phoneE164])
  @@index([receivedAt])
  @@index([sellerId])
  @@map("whatsapp_inbound_messages")
}

model WhatsAppOutboundMessage {
  id                 String         @id @default(cuid())
  phoneE164          String         @map("phone_e164")
  recipientId        String?        @map("recipient_id")
  recipientType      String?        @map("recipient_type")
  templateName       String?        @map("template_name")
  payload            Json?
  providerMessageId  String?        @map("provider_message_id")
  status             OutboundStatus @default(pending)
  failureReason      String?        @map("failure_reason")
  sentAt             DateTime?      @map("sent_at")
  deliveredAt        DateTime?      @map("delivered_at")
  readAt             DateTime?      @map("read_at")
  retryCount         Int            @default(0) @map("retry_count")
  nextRetryAt        DateTime?      @map("next_retry_at")
  createdAt          DateTime       @default(now()) @map("created_at")

  @@index([phoneE164])
  @@index([status])
  @@index([providerMessageId])
  @@map("whatsapp_outbound_messages")
}

model MatchGroup {
  id            String   @id @default(cuid())
  wishId        String   @map("wish_id")
  sellerId      String   @map("seller_id")
  matches       Json
  currentIndex  Int      @default(0) @map("current_index")
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([sellerId])
  @@index([wishId])
  @@index([expiresAt])
  @@map("match_groups")
}

model FeatureFlag {
  key         String   @id
  enabled     Boolean  @default(false)
  value       Json?
  description String?
  environment String   @default("production")
  updatedBy   String?  @map("updated_by")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("feature_flags")
}

model FeatureFlagHistory {
  id         String   @id @default(cuid())
  flagKey    String   @map("flag_key")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  changedBy  String?  @map("changed_by")
  changedAt  DateTime @default(now()) @map("changed_at")
  reason     String?

  @@index([flagKey])
  @@index([changedAt])
  @@map("feature_flag_history")
}

model WishRateCounter {
  sellerId String   @map("seller_id")
  date     DateTime @db.Date
  count    Int      @default(0)

  @@id([sellerId, date])
  @@map("wish_rate_counters")
}
